{
  "family": "ai-talent-api-gateway",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/ai-talent-platform-task-role",
  "containerDefinitions": [
    {
      "name": "api-gateway",
      "image": "<ACCOUNT_ID>.dkr.ecr.<REGION>.amazonaws.com/ai-talent-api-gateway:latest",
      "essential": true,
      "portMappings": [{ "containerPort": 8080, "hostPort": 8080 }],
      "environment": [
        { "name": "API_GATEWAY_PORT", "value": "8080" },
        { "name": "JWT_SECRET", "value": "<JWT_SECRET>" },
        { "name": "USER_SERVICE_INTERNAL_URL", "value": "http://user-service.internal:8081" },
        { "name": "CANDIDATE_SERVICE_INTERNAL_URL", "value": "http://candidate-service.internal:8082" },
        { "name": "NOTIFICATION_SERVICE_INTERNAL_URL", "value": "http://notification-service.internal:8083" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ai-talent-api-gateway",
          "awslogs-region": "<REGION>",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
