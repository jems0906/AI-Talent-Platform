{
  "family": "ai-talent-candidate-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/ai-talent-platform-task-role",
  "containerDefinitions": [
    {
      "name": "candidate-service",
      "image": "<ACCOUNT_ID>.dkr.ecr.<REGION>.amazonaws.com/ai-talent-candidate-service:latest",
      "essential": true,
      "portMappings": [{ "containerPort": 8082, "hostPort": 8082 }],
      "environment": [
        { "name": "CANDIDATE_SERVICE_PORT", "value": "8082" },
        { "name": "AI_SERVICE_URL", "value": "http://ai-ranking-service.internal:8084" },
        { "name": "NOTIFICATION_SERVICE_URL", "value": "http://notification-service.internal:8083" },
        { "name": "PGHOST", "value": "<RDS_ENDPOINT>" },
        { "name": "PGPORT", "value": "5432" },
        { "name": "PGDATABASE", "value": "talent_platform" },
        { "name": "DB_USERNAME", "value": "<DB_USERNAME>" },
        { "name": "DB_PASSWORD", "value": "<DB_PASSWORD>" },
        { "name": "JWT_SECRET", "value": "<JWT_SECRET>" },
        { "name": "STORAGE_PROVIDER", "value": "s3" },
        { "name": "STORAGE_S3_BUCKET", "value": "<S3_BUCKET_NAME>" },
        { "name": "AWS_REGION", "value": "<REGION>" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ai-talent-candidate-service",
          "awslogs-region": "<REGION>",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
