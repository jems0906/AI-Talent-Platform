{
  "family": "ai-talent-user-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/ai-talent-platform-task-role",
  "containerDefinitions": [
    {
      "name": "user-service",
      "image": "<ACCOUNT_ID>.dkr.ecr.<REGION>.amazonaws.com/ai-talent-user-service:latest",
      "essential": true,
      "portMappings": [{ "containerPort": 8081, "hostPort": 8081 }],
      "environment": [
        { "name": "USER_SERVICE_PORT", "value": "8081" },
        { "name": "USER_DB_URL", "value": "jdbc:postgresql://<RDS_ENDPOINT>:5432/talent_platform" },
        { "name": "DB_USERNAME", "value": "<DB_USERNAME>" },
        { "name": "DB_PASSWORD", "value": "<DB_PASSWORD>" },
        { "name": "JWT_SECRET", "value": "<JWT_SECRET>" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ai-talent-user-service",
          "awslogs-region": "<REGION>",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
